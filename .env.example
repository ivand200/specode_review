APP_ENV=development
LOG_LEVEL=INFO

# GitHub App installed only on the configured repository.
GITHUB_REPOSITORY=ivand200/test_repo
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=/path/to/github-app.private-key.pem
# Literal shared secret configured in the GitHub App; this is not a file path or ngrok.yml.
GITHUB_WEBHOOK_SECRET=replace-with-github-webhook-secret
# Optional reserved ngrok HTTPS origin. Leave empty to use a free-plan assigned URL.
NGROK_URL=

# Application-owned review policy plus exact Codex model and reasoning effort.
CODEX_MODEL=gpt-5.4
OPENAI_REASONING_EFFORT=high
REVIEW_KIT_PATH=/absolute/path/to/review-agent/review-kit

STATE_ROOT=/var/lib/review-agent
WORKSPACE_ROOT=/tmp/review-agent
# One deadline covers review, publication, and normal cleanup. Default: 15 minutes.
REVIEW_TIMEOUT_SECONDS=900

# Disposable sandbox and bounded subprocess settings.
SANDBOX_CPUS=2
SANDBOX_MEMORY_MIB=4096
SANDBOX_PIDS=256
PROCESS_OUTPUT_MAX_BYTES=1048576
CANDIDATE_OUTPUT_MAX_BYTES=65536
SANDBOX_CLEANUP_TIMEOUT_SECONDS=30
SANDBOX_NAME_PREFIX=review-agent-

# V0.1 supports one application process and one in-memory worker only. Queued or active
# reviews can be lost on abrupt restart and require manual GitHub webhook redelivery.

# Limits enforced by the current review core:
# - at most 100 changed files;
# - at most 5,000 changed text lines (binary files count only toward files);
# - at most 10,000 pull-request description characters, including the truncation marker;
# - at most 65,536 candidate JSON bytes;
# - at most 1,048,576 combined captured Git stdout/stderr bytes by default.
# The Docker lifecycle adapter applies validated CPU and memory budgets at sandbox creation,
# a per-command process-count limit, bounded sbx output capture, and sandbox-scoped deny-all
# networking. Startup requires the pinned sbx and Codex CLI versions documented in README.md,
# runs host diagnostics, and validates REVIEW_KIT_PATH before accepting traffic.
#
# Model-request, tool-call, and token-budget environment settings are intentionally absent:
# the current runtime cannot enforce them.
