# GitHub App identity and signed-webhook trust.
GITHUB_APP_ID=
GITHUB_WEBHOOK_SECRET=replace-with-github-webhook-secret
PUBLIC_WEBHOOK_URL=https://reviews.example.com/webhooks/github

# Optional reserved ngrok ingress. Leave both empty when ingress is managed separately.
NGROK_URL=
NGROK_AUTHTOKEN=

# Model policy and bounded host-wide admission.
CODEX_MODEL=gpt-5.4
OPENAI_REASONING_EFFORT=high
MAX_CONCURRENT_REVIEWS=3
LOG_LEVEL=INFO

# Application-owned production defaults are intentionally not configurable here:
# - GitHub App key: /opt/specode-review/.secrets/github-app.pem
# - trusted review kit: /opt/specode-review/review-kit
# - disposable workspaces: /var/lib/specode-review/workspaces
# - each Sandbox: 2 CPUs, 2048 MiB memory, and 256 processes
# - loopback bind: 127.0.0.1:8000
#
# Other fixed limits include 100 changed files, 5,000 changed text lines,
# 65,536 candidate JSON bytes, and 1,048,576 captured process-output bytes.
# Model credentials belong in the Docker Sandboxes host-managed credential proxy,
# never in this environment.
