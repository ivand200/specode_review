#!/bin/sh
set -eu

if [ "$#" -ne 2 ]; then
  echo "usage: review-diff START_SHA END_SHA" >&2
  exit 64
fi

start_sha=$1
end_sha=$2
repository=/home/agent/review/repo

printf '%s\n' "$start_sha" "$end_sha" | grep -Eq '^[0-9a-fA-F]{40}$' || exit 64
test "$(git -C "$repository" rev-parse HEAD)" = "$end_sha" || exit 65
exec git -C "$repository" diff --no-ext-diff "$start_sha" "$end_sha" --
